// ===========================================
// PDV FiadoDigital — Prisma Schema
// ===========================================
// SQLite com WAL mode obrigatório.
// Valores monetários em centavos (Int).
// Soft delete (deleted_at) em todas as entidades exceto AuditLog.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ------------------------------------------
// User — Operadores, gerentes, estoquistas
// ------------------------------------------
model User {
  id            String    @id @default(uuid())
  name          String
  username      String    @unique
  password_hash String
  pin_hash      String?
  role          String    // admin | manager | stockist | operator
  can_view_cost_price Boolean @default(false)
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  sales          Sale[]
  cash_registers CashRegister[]
  transactions   Transaction[]
  stock_movements StockMovement[]
  audit_logs     AuditLog[]     @relation("AuditActor")

  @@index([username])
  @@index([role])
  @@map("user")
}

// ------------------------------------------
// Customer — Clientes com controle de fiado
// ------------------------------------------
model Customer {
  id                String    @id @default(uuid())
  name              String
  phone             String?
  email             String?
  credit_limit_cents Int      @default(0)
  current_debt_cents Int      @default(0)
  payment_due_day   Int?
  credit_blocked    Boolean   @default(false)
  is_active         Boolean   @default(true)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?

  sales        Sale[]
  transactions Transaction[]

  @@index([name])
  @@index([deleted_at, is_active])
  @@index([deleted_at, name])
  @@index([deleted_at, payment_due_day])
  @@map("customer")
}

// ------------------------------------------
// Product — Catálogo de produtos
// ------------------------------------------
model Product {
  id              String    @id @default(uuid())
  name            String
  barcode         String?   @unique
  brand_id        String?
  description     String?
  weight_value    Float?
  weight_unit     String?
  product_type_id String?
  profit_margin   Int?
  price_cents     Int
  cost_price_cents Int
  average_cost_cents Int    @default(0)
  stock_quantity  Float     @default(0)
  min_stock_alert Int       @default(5)
  is_bulk         Boolean   @default(false)
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  brand       Brand?       @relation(fields: [brand_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product_type ProductType? @relation(fields: [product_type_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sale_items SaleItem[]
  stock_movements StockMovement[]

  @@index([barcode])
  @@index([name])
  @@index([brand_id])
  @@index([product_type_id])
  @@map("product")
}

model StockMovement {
  id              String   @id @default(uuid())
  product_id      String
  product         Product  @relation(fields: [product_id], references: [id])
  type            String   // entry | sale | adjustment
  quantity        Float    // positivo para entrada, negativo para saída
  unit_cost_cents Int      @default(0)
  description     String?
  operator_id     String
  created_at      DateTime @default(now())

  operator        User     @relation(fields: [operator_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([operator_id])
  @@index([product_id, created_at])
  @@index([created_at])
  @@map("stock_movements")
}

model Brand {
  id         String    @id @default(uuid())
  name       String    @unique
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?
  products   Product[]

  @@map("brands")
}

// ------------------------------------------
// ProductType — Classificação de produtos
// ------------------------------------------
model ProductType {
  id         String    @id @default(uuid())
  name       String    @unique
  profit_margin Int?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  products Product[]

  @@map("product_types")
}

// ------------------------------------------
// Sale — Vendas (UUID v7 para idempotência)
// ------------------------------------------
model Sale {
  id             String    @id @default(uuid())
  uuid           String    @unique
  operator_id    String
  customer_id    String?
  terminal_id    String
  payment_method String    // cash | pix | credit_card | debit_card | fiado | mixed
  subtotal_cents Int
  discount_cents Int       @default(0)
  total_cents    Int
  status         String    @default("completed") // pending | completed | cancelled | refunded
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  deleted_at     DateTime?

  operator     User       @relation(fields: [operator_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  customer     Customer?  @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  items        SaleItem[]
  payments     SalePayment[]
  transactions Transaction[]

  @@index([uuid])
  @@index([operator_id])
  @@index([customer_id])
  @@index([terminal_id])
  @@index([created_at])
  @@map("sale")
}

model SalePayment {
  id           String   @id @default(uuid())
  sale_id      String
  method       String   // cash | pix | credit_card | debit_card | fiado
  amount_cents Int
  installments Int?     // número de parcelas (crédito parcelado)
  applied_rate Int?     // taxa percentual aplicada pela operadora em basis points
  created_at   DateTime @default(now())
  deleted_at   DateTime?

  sale Sale @relation(fields: [sale_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([deleted_at])
  @@index([sale_id])
  @@index([method])
  @@map("sale_payment")
}

// ------------------------------------------
// SaleItem — Itens da venda (snapshot de preço)
// ------------------------------------------
model SaleItem {
  id               String @id @default(uuid())
  sale_id          String
  product_id       String
  product_name     String @default("Produto sem nome")
  quantity         Float
  unit_price_cents Int    // Snapshot do preço no ato da venda
  discount_cents   Int    @default(0)
  total_cents      Int

  sale    Sale    @relation(fields: [sale_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([sale_id])
  @@index([product_id])
  @@map("sale_item")
}

// ------------------------------------------
// CashRegister — Abertura e fechamento de caixa
// ------------------------------------------
model CashRegister {
  id                    String    @id @default(uuid())
  operator_id           String
  terminal_id           String
  opening_balance_cents Int
  closing_balance_cents Int?
  expected_balance_cents Int?
  difference_cents      Int?
  status                String    @default("open") // open | closed
  opened_at             DateTime  @default(now())
  closed_at             DateTime?

  operator     User          @relation(fields: [operator_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  transactions Transaction[]

  @@index([terminal_id])
  @@index([operator_id])
  @@index([status])
  @@map("cash_register")
}

// ------------------------------------------
// Transaction — Movimentações financeiras
// ------------------------------------------
model Transaction {
  id               String   @id @default(uuid())
  type             String   // sale | refund | cancellation | cash_in | cash_out | fiado_payment
  amount_cents     Int
  sale_id          String?
  customer_id      String?
  cash_register_id String
  operator_id      String
  debt_before_cents Int?
  description      String?
  created_at       DateTime @default(now())

  sale          Sale?        @relation(fields: [sale_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  customer      Customer?    @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cash_register CashRegister @relation(fields: [cash_register_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  operator      User         @relation(fields: [operator_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([type])
  @@index([sale_id])
  @@index([customer_id])
  @@index([cash_register_id])
  @@index([operator_id])
  @@index([created_at])
  @@map("transaction")
}

// ------------------------------------------
// AuditLog — Registro de auditoria (append-only)
// Sem updated_at nem deleted_at.
// ------------------------------------------
model AuditLog {
  id          String   @id @default(uuid())
  action      String
  actor_id    String
  entity_type String
  entity_id   String
  details     String?  // JSON serializado
  ip_address  String?
  terminal_id String?
  created_at  DateTime @default(now())

  actor User @relation("AuditActor", fields: [actor_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([actor_id])
  @@index([action])
  @@index([entity_type, entity_id])
  @@index([created_at])
  @@map("audit_log")
}

model CardMachine {
  id         String            @id @default(uuid())
  name       String
  is_active  Boolean           @default(true)
  absorb_fee Boolean           @default(true)
  rates      CardMachineRate[]
  created_at DateTime          @default(now())
  updated_at DateTime          @updatedAt
  deleted_at DateTime?

  @@index([deleted_at])
  @@index([is_active])
  @@map("card_machines")
}

model CardMachineRate {
  id                       String      @id @default(uuid())
  card_machine_id          String
  card_machine             CardMachine @relation(fields: [card_machine_id], references: [id], onDelete: Cascade)
  debit_rate               Int         @default(0) // taxa em basis points
  credit_base_rate         Int         @default(0) // taxa base do crédito à vista em basis points
  credit_incremental_rate  Int         @default(0) // taxa incremental por parcela extra em basis points
  max_installments         Int         @default(1)
  created_at               DateTime    @default(now())
  updated_at               DateTime    @updatedAt

  @@index([card_machine_id])
  @@map("card_machine_rates")
}

// ------------------------------------------
// Settings — Configurações do sistema
// ------------------------------------------
model Settings {
  id                        String    @id @default(uuid())
  key                       String    @unique
  value                     String
  backup_path               String?
  backup_frequency          String?
  backup_retention          Int?
  backup_cloud_enabled      Boolean   @default(false)
  backup_cloud_token        String?
  backup_encryption_enabled Boolean   @default(false)
  backup_password          String?
  backup_time               String?
  updated_at                DateTime  @updatedAt
  deleted_at                DateTime?

  @@index([deleted_at])
  @@map("settings")
}

model Notification {
  id              String    @id @default(uuid())
  type            String    // ex: "stock.low", "discount.limit", "fiado.limit", "refund.critical"
  severity        String    // "critical" | "high" | "medium" | "info"
  title           String
  message         String
  meta            String?   // JSON serializado — ex: { productId, saleId, customerId, redirectPath }
  target_roles    String    // JSON serializado — ex: ["admin", "manager"]
  read_at         DateTime?
  acknowledged_by String?   // user_id de quem confirmou
  created_at      DateTime  @default(now())

  @@index([severity, created_at])
  @@index([read_at, created_at])
  @@map("notifications")
}

// ------------------------------------------
// BackupHistory — Registro de execuções de backup
// ------------------------------------------
model BackupHistory {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now()) @map("created_at")
  sizeBytes    Int      @map("size_bytes")
  status       String   // success | error | pending
  filePath     String   @map("file_path")
  errorMessage String?  @map("error_message")

  @@index([status])
  @@index([createdAt])
  @@map("backup_history")
}

// ------------------------------------------
// PixTransaction — Controle de transações PIX
// ------------------------------------------
model PixTransaction {
  id                String    @id @default(uuid())
  tx_id             String    @unique
  amount_cents      Int
  status            String    // pending | confirmed | failed | expired
  created_at        DateTime  @default(now())
  expires_at        DateTime
  paid_at           DateTime?
  paid_amount_cents Int?
  updated_at        DateTime  @updatedAt

  @@index([status])
  @@index([created_at])
  @@map("pix_transaction")
}

