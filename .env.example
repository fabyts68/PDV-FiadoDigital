# ============================================
# PDV FiadoDigital — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env no repositório.

# --- Banco de Dados ---
DATABASE_URL="file:./data/data.db"

# --- Segurança & Criptografia ---
# Chave mestra estática (32 bytes em HEX = 64 caracteres) usada para criptografia nativa no banco (AES-256-GCM)
# Gere no terminal: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY="CHANGE_ME_field_encryption_key_64_chars_hex_recommended"

# --- Autenticação JWT ---
# Gere secrets seguros com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_jwt_secret_min_64_chars"
JWT_REFRESH_SECRET="CHANGE_ME_refresh_secret_min_64_chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Servidor ---
PORT=3000
NODE_ENV="development"
# Origens permitidas para requisições CORS. Pode ser uma string única ou uma lista separada por vírgulas.
# Exemplo múltiplo: "http://pdv-caixa.local,http://192.168.1.100,http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"
APP_TIME_ZONE="America/Sao_Paulo"

# --- Pix (QR Code Estático) ---
# Tipo da chave Pix usada pelo emissor do QR Code: cpf | cnpj | email | phone | random
PIX_KEY_TYPE="email"
# Valor da chave Pix cadastrada para recebimento
PIX_KEY=""
# Segredo compartilhado para validar callbacks e webhooks Pix recebidos pelo backend
PIX_WEBHOOK_SECRET="CHANGE_ME_pix_webhook_secret"
# Nome do recebedor exibido no payload EMV do QR Code
PIX_MERCHANT_NAME=""
# Cidade do recebedor exibida no payload EMV do QR Code
PIX_MERCHANT_CITY=""

# --- Backup (opcional) ---
BACKUP_LOCAL_PATH="./backups"
# AWS_S3_BUCKET=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION=""

# ─── Frontend (apps/web) ────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
