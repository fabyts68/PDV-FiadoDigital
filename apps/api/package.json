{
  "name": "@pdv/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "prisma db push --config prisma.config.ts",
    "db:migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
    "db:seed": "tsx prisma/seed.ts",
    "notifications:cleanup-duplicates": "tsx src/scripts/cleanup-notification-duplicates.ts",
    "db:studio": "prisma studio --config prisma.config.ts",
    "db:generate": "prisma generate --config prisma.config.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@pdv/shared": "workspace:*",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.11",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.5.12",
    "@vitest/coverage-v8": "^2.1.9",
    "prisma": "^7.4.2",
    "rimraf": "^5.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
