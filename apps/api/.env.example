# ─── Banco de Dados ─────────────────────────────────────────────────
DATABASE_URL=file:./data/dev.db

# ─── Segurança & Criptografia ───────────────────────────────────────
FIELD_ENCRYPTION_KEY=CHANGE_ME_field_encryption_key_64_chars_hex_recommended

# ─── Autenticação JWT ────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_minimum_32_chars_random_string
JWT_REFRESH_SECRET=CHANGE_ME_minimum_32_chars_different_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Servidor ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
APP_TIME_ZONE=America/Sao_Paulo

# ─── Pix (QR Code Estático) ──────────────────────────────────────────
PIX_KEY_TYPE=email
PIX_KEY=
PIX_WEBHOOK_SECRET=CHANGE_ME_pix_webhook_secret
PIX_MERCHANT_NAME=
PIX_MERCHANT_CITY=
